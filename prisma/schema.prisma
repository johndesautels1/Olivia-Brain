generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model admin_audit_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type String
  actor      String
  summary    String
  metadata   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@index([event_type, created_at(sort: Desc)], map: "admin_audit_logs_event_type_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model conversation_turns {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String                 @db.Uuid
  role            String
  content         String
  metadata        Json                   @default("{}")
  created_at      DateTime               @default(now()) @db.Timestamptz(6)
  embedding       Unsupported("vector")?
  expires_at      DateTime?              @db.Timestamptz(6)
  conversations   conversations          @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id, created_at(sort: Desc)], map: "conversation_turns_conversation_id_idx")
  @@index([embedding])
  @@index([expires_at], where: raw("(expires_at IS NOT NULL)"))
}

model conversations {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String?
  metadata           Json                 @default("{}")
  last_message_at    DateTime             @default(now()) @db.Timestamptz(6)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  client_id            String?
  conversation_turns   conversation_turns[]
  conversation_events  conversation_events[]
  journey_snapshots    journey_snapshots[]
  action_budgets       action_budgets[]

  @@index([client_id, created_at(sort: Desc)], map: "conversations_client_id_idx")
}

/// Event-sourced conversation ledger — typed, ordered events for replay and projections.
/// Layered on top of conversation_turns (additive, does not replace).
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model conversation_events {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id  String               @db.Uuid
  client_id        String?
  event_type       String
  sequence_num     Int
  payload          Json                 @default("{}")
  actor            String
  parent_event_id  String?              @db.Uuid
  created_at       DateTime             @default(now()) @db.Timestamptz(6)
  conversation     conversations        @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent_event     conversation_events? @relation("event_chain", fields: [parent_event_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  child_events     conversation_events[] @relation("event_chain")

  @@unique([conversation_id, sequence_num], map: "conversation_events_sequence_unique")
  @@index([conversation_id, sequence_num(sort: Asc)], map: "conversation_events_replay_idx")
  @@index([conversation_id, event_type], map: "conversation_events_type_idx")
  @@index([client_id, created_at(sort: Desc)], map: "conversation_events_client_idx", where: raw("(client_id IS NOT NULL)"))
  @@index([parent_event_id], map: "conversation_events_parent_idx", where: raw("(parent_event_id IS NOT NULL)"))
}

model foundation_traces {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id   String   @db.Uuid
  intent            String
  runtime_mode      String
  selected_provider String
  payload           Json     @default("{}")
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([conversation_id, created_at(sort: Desc)], map: "foundation_traces_conversation_id_idx")
}

model integration_test_runs {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integration_id String
  action         String
  ok             Boolean
  actor          String
  summary        String
  details        Json     @default("[]")
  tested_at      DateTime @default(now()) @db.Timestamptz(6)
  duration_ms    Int      @default(0)

  @@index([integration_id, tested_at(sort: Desc)], map: "integration_test_runs_integration_id_idx")
  @@index([tested_at(sort: Desc)])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model knowledge_chunks {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source      String
  chunk_index Int                    @default(0)
  chunk_text  String
  metadata    Json                   @default("{}")
  embedding   Unsupported("vector")?
  created_at  DateTime               @default(now()) @db.Timestamptz(6)
  client_id   String?
  expires_at  DateTime?              @db.Timestamptz(6)

  @@index([embedding])
  @@index([client_id, created_at(sort: Desc)], map: "knowledge_chunks_client_id_idx")
  @@index([expires_at], where: raw("(expires_at IS NOT NULL)"))
}

model mem0_memories {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id        String
  mem0_id          String    @unique
  memory_type      String    @default("general")
  content          String
  metadata         Json      @default("{}")
  importance_score Float     @default(0.5) @db.Real
  last_accessed_at DateTime  @default(now()) @db.Timestamptz(6)
  expires_at       DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([client_id, importance_score(sort: Desc)], map: "mem0_memories_client_id_idx")
  @@index([expires_at], where: raw("(expires_at IS NOT NULL)"))
  @@index([last_accessed_at], map: "mem0_memories_last_accessed_idx")
  @@index([mem0_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// Knowledge graph entity storage — hybrid public/private isolation
model graph_entities {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  type                  String                 @default("concept")
  properties            Json                   @default("{}")
  embedding             Unsupported("vector")?
  chunk_ids             String[]               @default([])
  source                String?
  client_id             String?
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime               @default(now()) @db.Timestamptz(6)
  outgoing_relationships graph_relationships[] @relation("source_entity")
  incoming_relationships graph_relationships[] @relation("target_entity")

  @@index([type], map: "graph_entities_type_idx")
  @@index([embedding], map: "graph_entities_embedding_idx")
  @@index([client_id, created_at(sort: Desc)], map: "graph_entities_client_id_idx")
}

/// Knowledge graph relationship storage — connects entities with typed, weighted edges
model graph_relationships {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_entity_id String          @db.Uuid
  target_entity_id String          @db.Uuid
  type             String          @default("related_to")
  label            String?
  weight           Float           @default(0.5) @db.Real
  properties       Json            @default("{}")
  evidence         String?
  client_id        String?
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  source_entity    graph_entities  @relation("source_entity", fields: [source_entity_id], references: [id], onDelete: Cascade)
  target_entity    graph_entities  @relation("target_entity", fields: [target_entity_id], references: [id], onDelete: Cascade)

  @@index([source_entity_id], map: "graph_relationships_source_idx")
  @@index([target_entity_id], map: "graph_relationships_target_idx")
  @@index([type], map: "graph_relationships_type_idx")
  @@index([client_id, created_at(sort: Desc)], map: "graph_relationships_client_id_idx")
}

/// Episodic memory — coherent conversation episodes with LLM-generated summaries.
/// Always private (client_id required). Created at conversation end.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model episodes {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id         String
  conversation_id   String                 @db.Uuid
  title             String
  summary           String
  topics            String[]               @default([])
  participants      String[]               @default([])
  outcome           String?
  turn_ids          String[]               @default([]) @db.Uuid
  start_at          DateTime               @db.Timestamptz(6)
  end_at            DateTime               @db.Timestamptz(6)
  embedding         Unsupported("vector")?
  linked_entity_ids String[]               @default([]) @db.Uuid
  parent_episode_id String?                @db.Uuid
  created_at        DateTime               @default(now()) @db.Timestamptz(6)
  parent_episode    episodes?              @relation("episode_chain", fields: [parent_episode_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  child_episodes    episodes[]             @relation("episode_chain")

  @@index([client_id, end_at(sort: Desc)], map: "episodes_client_id_idx")
  @@index([conversation_id], map: "episodes_conversation_id_idx")
  @@index([embedding], map: "episodes_embedding_idx")
  @@index([parent_episode_id], map: "episodes_parent_episode_id_idx", where: raw("(parent_episode_id IS NOT NULL)"))
}

/// Semantic memory — distilled facts, preferences, insights, and constraints.
/// Public facts (client_id NULL) shared. Private facts (client_id set) isolated.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model semantic_memories {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id           String?
  content             String
  category            String                 @default("fact")
  confidence          Float                  @default(0.7) @db.Real
  source_episode_ids  String[]               @default([]) @db.Uuid
  entity_ids          String[]               @default([]) @db.Uuid
  embedding           Unsupported("vector")?
  superseded_by       String?                @db.Uuid
  last_reinforced_at  DateTime               @default(now()) @db.Timestamptz(6)
  created_at          DateTime               @default(now()) @db.Timestamptz(6)
  superseding_memory  semantic_memories?     @relation("supersede_chain", fields: [superseded_by], references: [id], onDelete: SetNull, onUpdate: NoAction)
  superseded_memories semantic_memories[]    @relation("supersede_chain")

  @@index([client_id, confidence(sort: Desc)], map: "semantic_memories_client_confidence_idx")
  @@index([category], map: "semantic_memories_category_idx")
  @@index([embedding], map: "semantic_memories_embedding_idx")
  @@index([superseded_by], map: "semantic_memories_superseded_by_idx", where: raw("(superseded_by IS NOT NULL)"))
  @@index([last_reinforced_at], map: "semantic_memories_reinforced_idx")
}

/// Procedural memory — learned workflows, tool preferences, and patterns.
/// Public procedures (client_id NULL) shared. Private procedures (client_id set) isolated.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model procedural_memories {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id     String?
  name          String
  description   String
  trigger       String
  steps         Json                   @default("[]")
  category      String                 @default("workflow")
  success_count Int                    @default(0)
  failure_count Int                    @default(0)
  embedding          Unsupported("vector")?
  is_active          Boolean                @default(true)
  created_at         DateTime               @default(now()) @db.Timestamptz(6)
  updated_at         DateTime               @default(now()) @db.Timestamptz(6)
  journey_snapshots  journey_snapshots[]

  @@index([client_id, is_active], map: "procedural_memories_client_active_idx")
  @@index([category], map: "procedural_memories_category_idx")
  @@index([embedding], map: "procedural_memories_embedding_idx")
  @@index([name], map: "procedural_memories_name_idx")
}

/// Journey snapshot — point-in-time serialization of conversation state for instant resume.
/// Always private (client_id required). Links to active procedure and conversation events.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model journey_snapshots {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id      String                @db.Uuid
  client_id            String
  snapshot_type        String                @default("auto")
  active_procedure_id  String?               @db.Uuid
  procedure_step_index Int                   @default(0)
  collected_data       Json                  @default("{}")
  pending_questions    Json                  @default("[]")
  context_summary      String
  sentiment            String?
  last_event_sequence  Int                   @default(0)
  metadata             Json                  @default("{}")
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  conversation         conversations         @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  active_procedure     procedural_memories?  @relation(fields: [active_procedure_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([conversation_id, created_at(sort: Desc)], map: "journey_snapshots_conversation_idx")
  @@index([client_id, created_at(sort: Desc)], map: "journey_snapshots_client_idx")
  @@index([active_procedure_id], map: "journey_snapshots_procedure_idx", where: raw("(active_procedure_id IS NOT NULL)"))
}

/// Action budgets — caps on LLM calls, tool invocations, and API requests per conversation.
/// Prevents runaway loops and cost overruns. Atomic consume via RPC.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model action_budgets {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String        @db.Uuid
  client_id       String?
  budget_type     String
  max_allowed     Int
  consumed        Int           @default(0)
  period          String        @default("conversation")
  reset_at        DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  conversation    conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversation_id, budget_type], map: "action_budgets_unique")
  @@index([conversation_id], map: "action_budgets_conversation_idx")
  @@index([reset_at], map: "action_budgets_reset_idx", where: raw("(reset_at IS NOT NULL)"))
  @@index([client_id, created_at(sort: Desc)], map: "action_budgets_client_idx", where: raw("(client_id IS NOT NULL)"))
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pending_approvals {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tool_name           String
  action_name         String
  params              Json                  @default("{}")
  risk_level          String
  confidence_score    Float                 @db.Real
  reasoning           String
  requested_by        String
  client_id           String?
  conversation_id     String?
  status              String                @default("pending")
  expires_at          DateTime              @db.Timestamptz(6)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  resolved_at         DateTime?             @db.Timestamptz(6)
  resolved_by         String?
  resolution_note     String?
  tool_execution_logs tool_execution_logs[]

  @@index([client_id, created_at(sort: Desc)], map: "pending_approvals_client_idx", where: raw("(client_id IS NOT NULL)"))
  @@index([conversation_id, created_at(sort: Desc)], map: "pending_approvals_conversation_idx", where: raw("(conversation_id IS NOT NULL)"))
  @@index([status, expires_at(sort: Desc)], map: "pending_approvals_status_idx", where: raw("(status = 'pending'::text)"))
}

model tool_execution_logs {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tool_name         String
  action_name       String
  params            Json               @default("{}")
  result            Json?
  success           Boolean
  error_message     String?
  confidence_score  Float?             @db.Real
  approval_id       String?            @db.Uuid
  executed_by       String
  client_id         String?
  conversation_id   String?
  duration_ms       Int?
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  pending_approvals pending_approvals? @relation(fields: [approval_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([client_id, created_at(sort: Desc)], map: "tool_execution_logs_client_idx", where: raw("(client_id IS NOT NULL)"))
  @@index([success, created_at(sort: Desc)], map: "tool_execution_logs_success_idx")
  @@index([tool_name, action_name, created_at(sort: Desc)], map: "tool_execution_logs_tool_idx")
}

// ═══════════════════════════════════════════════════════════════════════════
// AGENT SYSTEM — 250-Agent Autonomous Dashboard
// ═══════════════════════════════════════════════════════════════════════════

/// Agent groups organize agents by category (persona, domain, infrastructure, integration)
model agent_groups {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique // "1A", "2B", etc.
  name        String
  description String?
  category    String   @default("domain") // persona, domain, infrastructure, integration
  sort_order  Int      @default(0)
  is_archived Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  agents      agents[]

  @@index([sort_order])
  @@index([category])
}

/// Individual agents in the 250-agent system
model agents {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id           String            @unique // "O1-001", "O2-015", etc.
  name               String
  description        String?
  group_id           String            @db.Uuid
  status             String            @default("initializing") // active, paused, disabled, error, initializing
  persona            String?           // olivia, cristiano, emelia, system
  llm_model          String            @default("gpt-4o")
  temperature        Float             @default(0.7) @db.Real
  max_tokens         Int               @default(4096)
  system_prompt      String?
  schedule_type      String            @default("on_demand") // on_demand, realtime, hourly, daily, weekly, event_driven, cron
  schedule_cron      String?
  rate_limit_per_min Int               @default(10)
  rate_limit_per_day Int               @default(100)
  total_runs         Int               @default(0)
  successful_runs    Int               @default(0)
  failed_runs        Int               @default(0)
  total_cost_usd     Float             @default(0) @db.Real
  avg_latency_ms     Float             @default(0) @db.Real
  performance_score  Float             @default(0) @db.Real
  last_run_at        DateTime?         @db.Timestamptz(6)
  last_error_at      DateTime?         @db.Timestamptz(6)
  last_error         String?
  is_archived        Boolean           @default(false)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @db.Timestamptz(6)
  agent_group        agent_groups      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  agent_runs         agent_runs[]
  agent_configs      agent_configs[]
  agent_briefings    agent_briefings[]
  agent_learnings    agent_learnings[]
  agent_metrics      agent_metrics[]

  @@index([group_id])
  @@index([status])
  @@index([persona], where: raw("(persona IS NOT NULL)"))
  @@index([performance_score(sort: Desc)])
  @@index([last_run_at(sort: Desc)])
}

/// Individual agent execution runs
model agent_runs {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id         String            @db.Uuid
  status           String            @default("running") // running, completed, failed, timeout, cancelled
  trigger_type     String            @default("manual") // manual, scheduled, event, api, cascade, user_request
  trigger_user_id  String?
  input_json       Json              @default("{}")
  output_json      Json              @default("{}")
  error_message    String?
  duration_ms      Int?
  tokens_used      Int?
  cost_usd         Float?            @db.Real
  llm_model        String?
  cascade_step     Int?
  started_at       DateTime          @default(now()) @db.Timestamptz(6)
  completed_at     DateTime?         @db.Timestamptz(6)
  agent            agents            @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  agent_learnings  agent_learnings[]

  @@index([agent_id, started_at(sort: Desc)])
  @@index([status, started_at(sort: Desc)])
  @@index([trigger_type, started_at(sort: Desc)])
}

/// Agent configuration key-value pairs
model agent_configs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id   String   @db.Uuid
  key        String
  value      String
  is_secret  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  agent      agents   @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@unique([agent_id, key])
  @@index([agent_id])
}

/// Agent briefings (daily summaries, alerts, milestones)
model agent_briefings {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id           String   @db.Uuid
  briefing_type      String   @default("daily") // daily, weekly, alert, milestone
  title              String
  summary            String
  findings_json      Json     @default("{}")
  recommendations_json Json   @default("{}")
  severity           String   @default("info") // info, warning, critical
  is_read            Boolean  @default(false)
  period_start       DateTime @db.Timestamptz(6)
  period_end         DateTime @db.Timestamptz(6)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  agent              agents   @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@index([agent_id, created_at(sort: Desc)])
  @@index([is_read, created_at(sort: Desc)])
  @@index([severity, created_at(sort: Desc)])
}

/// Agent learnings (patterns, preferences, corrections)
model agent_learnings {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id      String      @db.Uuid
  run_id        String?     @db.Uuid
  learning_type String      @default("insight") // pattern, preference, correction, insight, feedback, optimization
  title         String
  description   String
  data_json     Json        @default("{}")
  confidence    Float       @default(0.7) @db.Real
  applied_count Int         @default(0)
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  agent         agents      @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  run           agent_runs? @relation(fields: [run_id], references: [id], onDelete: SetNull)

  @@index([agent_id, is_active])
  @@index([learning_type])
  @@index([confidence(sort: Desc)])
}

/// Daily agent metrics for analytics/charting
model agent_metrics {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id          String   @db.Uuid
  date              DateTime @db.Date
  runs_total        Int      @default(0)
  runs_successful   Int      @default(0)
  runs_failed       Int      @default(0)
  avg_latency_ms    Float    @default(0) @db.Real
  total_cost_usd    Float    @default(0) @db.Real
  tokens_used       Int      @default(0)
  user_interactions Int      @default(0)
  performance_score Float    @default(0) @db.Real
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  agent             agents   @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@unique([agent_id, date])
  @@index([agent_id, date(sort: Desc)])
}

/// System alerts (cross-agent, system-level)
model system_alerts {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source     String   // "cascade", "agent_O1-001", "system"
  severity   String   @default("info") // info, warning, critical
  title      String
  message    String
  metadata   Json     @default("{}")
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([is_read, created_at(sort: Desc)])
  @@index([severity, created_at(sort: Desc)])
}

/// Feature toggles for system-wide kill switches
model feature_toggles {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  enabled     Boolean  @default(true)
  description String?
  updated_by  String?
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}
